NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/auratravel
JWT_SECRET=change-this-super-secret-key
JWT_EXPIRE=24h
FRONTEND_URL=http://localhost:5173

# Seed credentials used by npm run seed
SEED_ADMIN_NAME=Aura Admin
SEED_ADMIN_EMAIL=admin@auratravel.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_USER_NAME=Demo Traveller
SEED_USER_EMAIL=user@auratravel.local
SEED_USER_PASSWORD=User@12345

# RAG Service Configuration (for AI-powered itineraries)
RAG_API_URL=http://localhost:8501

# External APIs (Google Places, Booking.com, Skyscanner)
GOOGLE_PLACES_API_KEY=your_google_places_api_key
BOOKING_API_KEY=your_booking_api_key
RAPIDAPI_KEY=your_rapidapi_key

# Enable/disable external API data in responses
ENABLE_EXTERNAL_APIS=true
